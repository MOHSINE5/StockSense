# Copy to .env and set paths for your machine.
# Stockfish must be installed separately; this must point to the engine binary.
# Relative paths are resolved from the backend/ folder.

# Windows (typical after unzip):
# STOCKFISH_PATH=C:\Path\To\stockfish-windows-x86-64-avx2.exe
# Or place the .exe under ../stockfish/ from backend:
# STOCKFISH_PATH=../stockfish/stockfish.exe

STOCKFISH_PATH=/path/to/stockfish

# Comma-separated origins for CORS (frontend dev server).
CORS_ORIGINS=http://localhost:5173
